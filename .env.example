# В Railway добавь это в Variables, в репозиторий реальный токен не загружай:
TELEGRAM_BOT_TOKEN=123456:telegram_token_here

# Необязательно. Если подключишь Railway Volume на /data, история будет лежать там.
DATA_DIR=/data

# Дефолты ускоренной проверки public.txt. Их можно менять прямо в Telegram:
# ⚡ Настройки public.txt → Public MAX/SAFE или ручные параметры.
BALANCE_BATCH_SIZE=100
BALANCE_BATCH_WORKERS=16
BALANCE_SCAN_WORKERS=48
BALANCE_REQUEST_TIMEOUT=5
BLOCKCYPHER_TOKEN=
BLOCKCHAIR_API_KEY=
